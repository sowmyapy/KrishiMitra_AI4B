# Test Environment Configuration
# Use this for local testing without external services

# Application
APP_NAME=KrishiMitra
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database (SQLite for testing)
DATABASE_URL=sqlite:///./test_krishimitra.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis (optional for testing)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Kafka (optional for testing)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=krishimitra-test

# AWS (dummy values for testing)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test_access_key
AWS_SECRET_ACCESS_KEY=test_secret_key
S3_BUCKET_SATELLITE=test-satellite-bucket
S3_BUCKET_AUDIO=test-audio-bucket

# Satellite Data (dummy values)
SENTINEL_HUB_CLIENT_ID=test_client_id
SENTINEL_HUB_CLIENT_SECRET=test_client_secret
GOOGLE_EARTH_ENGINE_KEY=

# Weather Data (dummy values)
OPENWEATHERMAP_API_KEY=test_weather_key
NOAA_API_KEY=

# Voice Services (dummy values)
TWILIO_ACCOUNT_SID=test_twilio_sid
TWILIO_AUTH_TOKEN=test_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=

# LLM Services (dummy values - replace with real keys for AI features)
OPENAI_API_KEY=sk-test-key-replace-with-real
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=test_elevenlabs_key

# Vector Database
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Security (CHANGE THESE IN PRODUCTION!)
JWT_SECRET_KEY=test-secret-key-change-in-production-use-strong-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=test-encryption-key-32-bytes!!

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Feature Flags
ENABLE_AGENTIC_AI=True
ENABLE_VOICE_CHATBOT=True
ENABLE_CONTINUOUS_LEARNING=True

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Cost Optimization
USE_REGIONAL_TILES=True
ENABLE_CACHING=True
CACHE_HIT_RATE_TARGET=0.85

# Supported Languages
SUPPORTED_LANGUAGES=hi,bn,te,mr,ta,gu,kn,ml,pa,or,en
