# Application
APP_NAME=KrishiMitra
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/krishimitra
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=krishimitra-consumers

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_SATELLITE=krishimitra-satellite-tiles
S3_BUCKET_AUDIO=krishimitra-audio-recordings

# Satellite Data Provider
SENTINEL_HUB_CLIENT_ID=your_client_id
SENTINEL_HUB_CLIENT_SECRET=your_client_secret
GOOGLE_EARTH_ENGINE_KEY=your_gee_key

# Weather Data Provider
OPENWEATHERMAP_API_KEY=your_api_key
NOAA_API_KEY=your_api_key

# Voice Services
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token

# LLM Services
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
ELEVENLABS_API_KEY=your_elevenlabs_key

# LLM Provider Selection
# Options: openai, bedrock
LLM_PROVIDER=openai
# Set to True to use AWS services (Bedrock, Transcribe, Polly) instead of OpenAI/ElevenLabs
USE_AWS_SERVICES=False

# Vector Database
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Security
JWT_SECRET_KEY=your_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your_encryption_key_here

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Feature Flags
ENABLE_AGENTIC_AI=true
ENABLE_VOICE_CHATBOT=true
ENABLE_CONTINUOUS_LEARNING=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Cost Optimization
USE_REGIONAL_TILES=true
ENABLE_CACHING=true
CACHE_HIT_RATE_TARGET=0.85

# Supported Languages (comma-separated ISO 639-1 codes)
SUPPORTED_LANGUAGES=hi,bn,te,mr,ta,gu,kn,ml,pa,or
